@model IEnumerable<finalProj.Models.Product>

@{
    ViewData["Title"] = "Store Catalog";
}

<div class="container mt-4">
    @* الـ Header المعدل: العنوان وزرار الإضافة في سطر واحد *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary mb-0"><i class="bi bi-bag-check"></i> StoreHub</h2>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4">
                <i class="bi bi-plus-circle"></i> Add New Product
            </a>
        }
    </div>

    @* قسم الفلتر والبحث *@
    <div class="card shadow-sm border-0 mb-5" style="background-color: #f8f9fa;">
        <div class="card-body">
            <form asp-action="Index" method="get" id="filterForm">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="small fw-bold text-muted">Search Product</label>
                        <input type="text" id="searchInput" name="searchString" value="@ViewData["CurrentFilter"]"
                               class="form-control" placeholder="Search by name or SKU..." autocomplete="off" />
                    </div>

                    <div class="col-md-4">
                        <label class="small fw-bold text-muted">Category</label>
                        <select name="categoryId" asp-items="ViewBag.CategoryId" id="categorySelect" class="form-select">
                            <option value="0">All Categories</option>
                        </select>
                    </div>

                    <div class="col-md-3 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1 shadow-sm">
                            Apply Filter
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">Clear</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @* عرض المنتجات *@
    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <h4 class="text-muted">No products found matching your search.</h4>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4 col-sm-6 mb-4">
                    <div class="card h-100 shadow-sm border-0 hover-shadow" style="transition: 0.3s;">
                        <div style="height: 220px; overflow: hidden; position: relative;">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/products/default.jpg" : item.ImageUrl)"
                                 class="card-img-top" alt="@item.Name"
                                 style="object-fit: cover; height: 100%; width: 100%;">

                            @if (item.StockQuantity <= 0)
                            {
                                <span class="badge bg-danger position-absolute top-0 end-0 m-2">Out of Stock</span>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h5 class="card-title mb-0 text-dark fw-bold">@item.Name</h5>
                                    <small class="text-muted">SKU: @item.SKU</small>
                                </div>
                                <span class="badge bg-light text-primary border border-primary">@item.Category?.Name</span>
                            </div>

                            <p class="card-text text-success h5 fw-bold mt-2">@item.Price.ToString("N2") EGP</p>

                            <div class="mt-auto pt-3 border-top">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="btn-group">
                                        @* details button *@
                                        <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary">View</a>

                                        @* buttons for admin only *@
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <div class="d-flex flex-column gap-2 border-bottom pb-2 mb-2">
                                                <div class="btn-group w-100">
                                                    <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-warning">Edit</a>
                                                    <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-danger">Delete</a>
                                                </div>

                                                @* فورم تزويد المخزن - مخفية عن اليوزر وعظيمة للأدمن *@
                                                <form asp-action="UpdateStock" method="post" class="input-group input-group-sm">
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <input type="number" name="extraQuantity" class="form-control" placeholder="Add Qty" min="1" required />
                                                    <button type="submit" class="btn btn-success">
                                                        <i class="bi bi-plus-lg"></i>
                                                    </button>
                                                </form>
                                                <small class="text-muted">Current Stock: <strong>@item.StockQuantity</strong></small>
                                            </div>
                                        }
                                    </div>

                                    @* button add to card with validation for quantity *@
                                    <div class="ms-auto">
                                        @if (item.StockQuantity > 0)
                                        {
                                            <a asp-controller="Cart"
                                               asp-action="AddToCart"
                                               asp-route-id="@item.ProductId"
                                               class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm">
                                                <i class="bi bi-cart-plus"></i> Add
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm">
                                                <i class="bi bi-x-circle"></i> Out of Stock
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            const form = $('#filterForm');
            const searchInput = $('#searchInput');
            const categorySelect = $('#categorySelect');

            //  بتبعت الفورم بعد تأخير بسيط عشان ميبعتش مع كل حرف (Debounce)
            let timeout = null;
            searchInput.on('keyup', function () {
                clearTimeout(timeout);
                timeout = setTimeout(function () {
                    form.submit();
                }, 500); // نص ثانية تأخير
            });

            // اول ما احدد الكاتيجوري بيفلترهم
            categorySelect.on('change', function () {
                form.submit();
            });

            // خلي الماوس يروح لآخر الكلام في الانبوت بعد الريفرش
            var strLength = searchInput.val().length;
            searchInput.focus();
            searchInput[0].setSelectionRange(strLength, strLength);
        });
    </script>
}