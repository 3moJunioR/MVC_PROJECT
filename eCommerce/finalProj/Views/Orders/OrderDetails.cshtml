@model finalProj.Models.Order

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-info-circle"></i> Order Details #@Model.OrderNumber</h2>
        <a asp-action="AdminOrders" class="btn btn-secondary">Back to List</a>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">Customer Info</div>
                <div class="card-body">
                    <p><strong>Name:</strong> @Model.User?.UserName</p>
                    <p><strong>Email:</strong> @Model.User?.Email</p>
                    <p><strong>Date:</strong> @Model.OrderDate.ToString("f")</p>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">Shipping Address</div>
                <div class="card-body">
                    <p>@Model.ShippingAddress?.Street, @Model.ShippingAddress?.City</p>
                    <p>@Model.ShippingAddress?.Country - @Model.ShippingAddress?.Zip</p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light">Items in this Order</div>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td>@item.Product?.Name</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.UnitPrice.ToString("N2") EGP</td>
                                    <td class="fw-bold">@item.LineTotal.ToString("N2") EGP</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-info">
                                <td colspan="3" class="text-end fw-bold">Grand Total:</td>
                                <td class="fw-bold text-success">@Model.TotalAmount.ToString("N2") EGP</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>