@model IEnumerable<finalProj.Models.Order>

@{
    ViewData["Title"] = "طلباتي";
}

<div class="container mt-4">
    <h2>قائمة طلباتي</h2>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            لا يوجد لديك أي طلبات سابقة حتى الآن.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>رقم الطلب</th>
                    <th>التاريخ</th>
                    <th>الإجمالي</th>
                    <th>الحالة</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.OrderNumber</td>
                        <td>@order.OrderDate.ToString("yyyy-MM-dd")</td>
                        <td>@order.TotalAmount.ToString("C")</td>
                        <td>
                            @if (order.Status == finalProj.Models.Order.OrderStatus.Pending)
                            {
                                <span class="badge bg-warning text-dark">قيد الانتظار</span>
                            }
                            else if (order.Status == finalProj.Models.Order.OrderStatus.Shipped)
                            {
                                <span class="badge bg-info">تم الشحن</span>
                            }
                            else
                            {
                                <span class="badge bg-success">تم التوصيل</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a asp-controller="Products" asp-action="Index" class="btn btn-secondary">العودة للتسوق</a>
    </div>
</div>