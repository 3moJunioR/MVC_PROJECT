@model List<finalProj.Models.CartItem>

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4"><i class="bi bi-cart3"></i> Your Shopping Cart</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info py-5 text-center">
            <h4>Your cart is empty!</h4>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-3">Go Shopping</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <table class="table align-middle shadow-sm bg-white rounded">
                    <thead class="table-light">
                        <tr>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@item.ImageUrl" width="50" height="50" style="object-fit:cover;" class="rounded me-3" />
                                        <span class="fw-bold">@item.ProductName</span>
                                    </div>
                                </td>
                                <td>@item.Price.ToString("N2") EGP</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <a asp-action="Decrease" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-secondary rounded-circle">
                                            <i class="bi bi-dash"></i>
                                        </a>

                                        <span class="fw-bold px-2">@item.Quantity</span>

                                        <a asp-action="Increase" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-secondary rounded-circle">
                                            <i class="bi bi-plus"></i>
                                        </a>
                                    </div>
                                </td>

                                <td class="fw-bold text-primary">@item.Total.ToString("N2") EGP</td>
                                <td class="text-end">
                                    <a asp-action="RemoveFromCart" asp-route-id="@item.ProductId" class="text-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0 pt-3">
                    <div class="card-body">
                        <h5 class="card-title fw-bold border-bottom pb-3">Order Summary</h5>
                        <div class="d-flex justify-content-between my-3">
                            <span>Subtotal:</span>
                            <span class="fw-bold">@Model.Sum(x => x.Total).ToString("N2") EGP</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 text-success h5">
                            <strong>Total:</strong>
                            <strong>@Model.Sum(x => x.Total).ToString("N2") EGP</strong>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-controller="Orders" asp-action="Checkout" class="btn btn-success btn-lg w-100 fw-bold shadow-sm">
                                Proceed to Checkout <i class="bi bi-arrow-right"></i>
                            </a>

                            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary mt-2">
                                <i class="bi bi-arrow-left"></i> Continue Shopping
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>